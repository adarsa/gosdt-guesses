\name{gosdt_lib_version}
\alias{gosdt_lib_version}
\title{Placeholder version string for R bindings}
\usage{
gosdt_lib_version()
}
\value{
A character string (placeholder until the full API is implemented).
}
\description{
Reports a build identifier for the experimental R bindings. The native
solver objects from \verb{libgosdt} are linked into the package shared
library; this function does not yet expose optimization results.
}
